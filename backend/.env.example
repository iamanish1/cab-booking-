PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/cab-booking
REDIS_URL=
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
CUSTOMER_CASHBACK_TARGET=10
CUSTOMER_CASHBACK_BONUS=20
DEFAULT_CITY=Delhi
LOG_LEVEL=info
WEBHOOK_SIGNATURE_SECRET=replace-with-webhook-secret
NODE_ENV=development
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number
